{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentdiff.dev/schemas/execution_plan.v1.json",
  "title": "AgentDiff Execution Plan v1",
  "type": "object",
  "required": ["steps"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Optional plan format version"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "files"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "intent": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
